# Agent God OS — Configuración del usuario
# Copia este archivo a .env y ajusta los valores

# Directorio raíz donde están tus proyectos
# Linux default:  ~/Documentos/Proyectos
# macOS default:  ~/Documents/Projects
PROJECTS_DIR=~/Documentos/Proyectos

# Directorio home del usuario (se detecta automáticamente, solo cambia si necesitas override)
HOST_HOME=${HOME}
